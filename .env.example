# Copy to `.env.local` and fill in your Supabase project values.
# Both keys below are PUBLIC and safe to expose in the browser bundle —
# Row Level Security policies protect data, not the keys.
#
# Find them at: https://supabase.com/dashboard/project/_/settings/api-keys
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
